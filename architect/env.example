# Output
OUTPUT_DIR=output

# Temporal
TEMPORAL_HOST=localhost:7233

# Consul (default — no change needed if using docker-compose)
CONSUL_HOST=http://localhost:8500

# Agent Connector (timeout in seconds for real agent HTTP calls)
AGENT_CONNECTOR_TIMEOUT=300
