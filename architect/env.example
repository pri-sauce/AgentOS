# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# PostgreSQL (your DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=architect
DB_USER=postgres
